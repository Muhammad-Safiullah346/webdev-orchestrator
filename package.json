{
  "name": "webdev-orchestrator",
  "version": "1.1.8",
  "description": "Multi-agent web-development workflow on the Claude Agent SDK. Real isolated subagents, deterministic PM orchestration, file-based memory, per-role model lanes, and an anti-slop design layer. Works in any project: greenfield, iteration, bugfix, refactor, UI polish, migration, audit.",
  "type": "module",
  "bin": {
    "webdev": "bin/webdev"
  },
  "files": [
    "bin",
    "src",
    ".claude",
    "!.claude/settings.local.json",
    "!.claude/**/settings.local.json",
    "NOTICE"
  ],
  "scripts": {
    "webdev": "tsx src/cli.ts",
    "doctor": "tsx src/cli.ts doctor",
    "setup": "tsx src/cli.ts setup",
    "typecheck": "tsc --noEmit",
    "install-skills": "tsx src/cli.ts install-skills",
    "release": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "preversion": "npm run typecheck",
    "prepublishOnly": "npm run typecheck"
  },
  "keywords": [
    "claude",
    "claude-agent-sdk",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "code-generation",
    "web-development",
    "anti-slop",
    "design-system",
    "subagents",
    "cli"
  ],
  "author": "Muhammad Safiullah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-Safiullah346/webdev-orchestrator.git"
  },
  "homepage": "https://github.com/Muhammad-Safiullah346/webdev-orchestrator#readme",
  "bugs": {
    "url": "https://github.com/Muhammad-Safiullah346/webdev-orchestrator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "tsx": "^4.22.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
